# Hugging Face token. Get one at https://huggingface.co/settings/tokens
# Required only for gated models (Llama, Mistral, ...). Qwen does NOT need it.
HF_TOKEN=

# Model id (any HF chat-tuned model that vLLM supports).
MODEL=Qwen/Qwen2.5-7B-Instruct

# Local Hugging Face cache (so model weights survive container restarts).
HF_CACHE=${HOME}/.cache/huggingface
