# =========================================================================
# Pure-NVIDIA stack. No Hugging Face tokens, no HF downloads.
# Weights come from NGC via the NIM's `download-to-cache` and are shared
# between the baseline NIM container and the disagg Dynamo container.
# =========================================================================

# --- NVIDIA NGC API key (required) ---
# Get one at https://org.ngc.nvidia.com/setup/api-key. Used to:
#   1. Pull NIM container weights via `download-to-cache`.
#   2. `docker login nvcr.io` (run once, separately) before pulling images.
NGC_API_KEY=

# --- Model served by every scenario ---
# Resolves to the NGC artifact ngc://nim/nvidia/nemotron-3-nano. A NemotronH
# hybrid (Mamba2 + Transformer) model. The same weight files on disk are read
# by the NIM baseline and the Dynamo disagg workers.
MODEL=nvidia/nemotron-3-nano

# --- Local weight cache (host path; mounted into every container) ---
# Created on first `download-to-cache`. GID 0 needs rwx so the NIM can write:
#   mkdir -p $NIM_CACHE_PATH && chmod -R g+rwX $NIM_CACHE_PATH && chgrp -R 0 $NIM_CACHE_PATH
NIM_CACHE_PATH=${HOME}/.cache/nim
